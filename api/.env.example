# PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/vividnexus

# LM Studio (OpenAI-compatible)
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_CHAT_MODEL=qwen2.5-coder-7b-instruct
LLM_EMBEDDING_MODEL=nomic-embed-text-v1.5.f32
EMBEDDING_DIM=768

# API
API_HOST=0.0.0.0
API_PORT=8000

# Motor do mundo
# Quantos segundos reais entre ticks automáticos. 0 desliga o scheduler.
WORLD_TICK_INTERVAL_SECONDS=10
# Quantos minutos de jogo cada tick avança.
WORLD_MINUTES_PER_TICK=15
# Hora inicial do mundo (formato HH:MM, 24h). Padrão: 06:00.
WORLD_START_TIME=06:00
